{
  "name": "@aaarc/handfree-ssh-mcp",
  "version": "1.0.15",
  "description": "Handfree SSH MCP Server - A hands-free SSH automation tool via MCP protocol",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "handfree-ssh-mcp": "build/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ironboxplus/handfree-ssh-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Ironboxplus/handfree-ssh-mcp/issues"
  },
  "homepage": "https://github.com/Ironboxplus/handfree-ssh-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "npm run build && node --test build/tests/config.test.js build/tests/command-validation.test.js build/tests/tool-error.test.js build/tests/tools.test.js build/tests/output-collector.test.js build/tests/output-log-writer.test.js build/tests/recent-fixes.test.js build/tests/sftp-stall-timeout.test.js build/tests/keepalive-channel-open.test.js",
    "test:config": "npm run build && node --test build/tests/config.test.js",
    "test:cmd": "npm run build && node --test build/tests/command-validation.test.js",
    "test:tools": "npm run build && node --test build/tests/tools.test.js",
    "test:integration": "npm run build && node build/tests/integration.test.js",
    "test:all": "npm run test && npm run test:integration",
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ssh",
    "mcp",
    "server",
    "cli"
  ],
  "author": "Junki",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.17.5",
    "js-yaml": "^4.1.0",
    "socks": "^2.8.6",
    "ssh2": "^1.16.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/ssh2": "^1.15.5",
    "typescript": "^5.8.2"
  },
  "files": [
    "build/config/**/*",
    "build/core/**/*",
    "build/models/**/*",
    "build/services/**/*",
    "build/tools/**/*",
    "build/utils/**/*",
    "build/index.js"
  ]
}
